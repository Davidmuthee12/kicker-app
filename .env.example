# Client-side endpoint used by the registration form.
# Keep /api/form when you want Next.js route handler proxying to your backend.
NEXT_PUBLIC_REGISTER_API_ENDPOINT=/api/form

# Server-side backend base URL used by app/api/form/route.ts
# Dev example: http://localhost:8080
# Prod example: https://api.yourdomain.com
API_BASE_URL=http://localhost:8080

# Backend register path appended to API_BASE_URL
API_REGISTER_PATH=/auth/register
